# ============================
# Nono Agent Configuration
# Copy this file to .env and fill in your keys
# ============================

# === LLM Config ===
# Switch models by changing this single line (format: provider/model)
MODEL=

# === API Keys (fill in at least one for the model you want to use) ===
# Alibaba Cloud DashScope (Qwen): https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=
# Google Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Anthropic Claude: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# DeepSeek: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# === Telegram Bot (optional) ===
# Search @BotFather in Telegram → /newbot to create a bot and get a Token
TELEGRAM_BOT_TOKEN=
# Restrict allowed Telegram user IDs (numeric, comma-separated, leave empty for unrestricted)
TELEGRAM_ALLOWED_USERS=

# === Feishu Bot (optional) ===
# Create an enterprise app on Feishu Open Platform to get these credentials
# See docs/feishu_setup.md for details
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Restrict allowed user open_ids (comma-separated, leave empty for unrestricted)
FEISHU_ALLOWED_USERS=

# === Syncthing File Sync (optional) ===
SYNCTHING_API_KEY=

# === Workspace Directory ===
# The Agent's default working directory. If not set, it auto-detects
# from Syncthing's first synced folder, or falls back to ~/
WORKSPACE_DIR=
